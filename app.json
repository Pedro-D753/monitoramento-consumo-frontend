{
  "expo": {
    "name": "Liqua",
    "slug": "LiquaMonitor",
    "scheme": "liqua",
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      "expo-image"
    ],
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/liquaLogo.webp",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./src/assets/liquaLogo.webp",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.liquamonitor.liqua",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "app.liquamonitor.dev",
              "pathPrefix": "/reset-password"
            },
            {
              "scheme": "https",
              "host": "frontend.liquamonitor.dev",
              "pathPrefix": "/reset-password"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "softwareKeyboardLayoutMode": "pan",
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/liquaLogo.webp",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/liquaLogo.png"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e85c32aa-df25-4bc8-b2fc-edcd5a7c9e20"
      }
    }
  }
}
